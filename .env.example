# Planet v2 configuration

# Where the SQLite database file lives
DATABASE_PATH=./data/planet.sqlite

# Session signing secret (change in production)
SESSION_SECRET=dev-insecure-session-secret-change-me

# Public site origin, used for absolute links (RSS, share links)
PUBLIC_SITE_ORIGIN=http://localhost:3030

# --- Forward auth (trusted reverse-proxy header) ---
# When enabled, identity comes from an upstream auth proxy (Authelia,
# oauth2-proxy, Traefik forward-auth, ...) and built-in sign-in/sign-up are
# disabled. Only enable behind a proxy that sets these headers and strips any
# client-supplied copies.
FORWARD_AUTH=0
FORWARD_AUTH_USER_HEADER=Remote-User
FORWARD_AUTH_EMAIL_HEADER=Remote-Email
FORWARD_AUTH_NAME_HEADER=Remote-Name
# Proxy auth endpoint that the "Sign in" link and auth-required pages point to.
FORWARD_AUTH_LOGIN_PATH=/.login

# --- S3 (image store) ---
# Any S3-compatible endpoint works (AWS S3, Cloudflare R2, MinIO, ...)
S3_REGION=auto
S3_ENDPOINT=
S3_BUCKET=planet-images
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Public base URL that serves the bucket's objects (CDN or bucket public URL)
S3_PUBLIC_BASE_URL=http://localhost:3030/img
